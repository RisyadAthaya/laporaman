rules_version = '2';

// NOTE: this repo has no firebase.json/.firebaserc — these rules are drafted
// for the "reports" collection's upvote feature but are NOT deployed yet.
// To apply them: `firebase init` (Firestore) in this directory, then
// `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {
    // Regular accounts get DEFAULT_DAILY_REPORT_LIMIT reports/day (see
    // markerService.js); accounts flagged as an authority in /users/{uid}
    // get AUTHORITY_DAILY_REPORT_LIMIT. There's no in-app way to become an
    // authority yet — the role is set by hand in the Firestore console.
    function isAuthority(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.role == 'authority';
    }

    function dailyReportLimit(uid) {
      return isAuthority(uid) ? 20 : 5;
    }

    function isSameCalendarDay(a, b) {
      return a.year() == b.year() && a.month() == b.month() && a.day() == b.day();
    }

    match /users/{uid} {
      allow read: if true;
      // Role assignment is manual (Firebase console / Admin SDK) for now —
      // no client is allowed to write its own role.
      allow write: if false;
    }

    // Tracks each user's report count for the current calendar day. Written
    // in the same batch as the report it gates, so a client can't create a
    // report without also paying for it here. lastReportAt must be
    // request.time (a server-set timestamp), so a client can't backdate it
    // to dodge the daily reset.
    match /rateLimits/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['lastReportAt', 'count'])
        && request.resource.data.lastReportAt == request.time
        && request.resource.data.count == 1;

      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['lastReportAt', 'count'])
        && request.resource.data.lastReportAt == request.time
        && (
          (
            !isSameCalendarDay(resource.data.lastReportAt, request.time)
            && request.resource.data.count == 1
          )
          || (
            isSameCalendarDay(resource.data.lastReportAt, request.time)
            && request.resource.data.count == resource.data.count + 1
            && request.resource.data.count <= dailyReportLimit(uid)
          )
        );

      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null
        && (
          !exists(/databases/$(database)/documents/rateLimits/$(request.auth.uid))
          || !isSameCalendarDay(get(/databases/$(database)/documents/rateLimits/$(request.auth.uid)).data.lastReportAt, request.time)
          || get(/databases/$(database)/documents/rateLimits/$(request.auth.uid)).data.count < dailyReportLimit(request.auth.uid)
        );
      allow delete: if false;

      // Only allow authenticated users to update voteCount/voterIds, and only
      // by adding or removing exactly their own uid.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voteCount', 'voterIds'])
        && (
          (
            request.resource.data.voterIds.size() == resource.data.voterIds.size() + 1 &&
            request.resource.data.voterIds.toSet() == resource.data.voterIds.toSet().union([request.auth.uid]) &&
            request.resource.data.voteCount == resource.data.voteCount + 1
          ) ||
          (
            request.resource.data.voterIds.size() == resource.data.voterIds.size() - 1 &&
            resource.data.voterIds.toSet() == request.resource.data.voterIds.toSet().union([request.auth.uid]) &&
            request.resource.data.voteCount == resource.data.voteCount - 1
          )
        );
    }
  }
}
